---
import Base from '../layouts/Base.astro';
import data from '../../data/releases.json';

const releases = data.releases || [];
const latest = releases[0] || {};
const recent = releases.slice(0, 6);
// 안정화(데이터무결성/보안/호환성) 하이라이트
const stable = releases.filter(r => ['data-integrity', 'security', 'compat'].includes(r.category)).slice(0, 5);
const total = data.count || releases.length;
const importantCount = releases.filter(r => r.important).length;
const badgeClass = (c) => ['security','data-integrity','feature','compat','performance','consistency','refactor','fix'].includes(c) ? c : 'fix';
---
<Base title="leerness — AI 코딩 에이전트를 위한 운영 레이어">
  <section class="hero">
    <h1>AI 코딩 에이전트를 위한<br /><span class="grad">운영 레이어 (operating layer)</span></h1>
    <p class="tag">기억 · 인수인계 · 검증 · 감사 · 보안 가드를 <code>.harness/</code> 에 영속화 — 코드를 대신 쓰지 않고, 어떤 에이전트 위에도 얹는 공통 운영 계층. 0 의존성 · offline-first · MCP 85 도구.</p>
    <div class="install"><span class="pfx">$ </span>npm i -g leerness</div>
    <div class="cta">
      <a class="btn primary" href="/how-it-works">leerness가 해주는 일 →</a>
      <a class="btn ghost" href="/changelog">패치노트</a>
      <a class="btn ghost" href="https://github.com/gugu9999gu/leerness" target="_blank" rel="noopener">GitHub</a>
    </div>
    <div class="stats">
      <div class="stat"><div class="n">v{latest.version || '—'}</div><div class="l">최신 버전</div></div>
      <div class="stat"><div class="n">{total}</div><div class="l">릴리스</div></div>
      <div class="stat"><div class="n">0</div><div class="l">의존성</div></div>
      <div class="stat"><div class="n">85</div><div class="l">MCP 도구</div></div>
    </div>
  </section>

  <section id="plain">
    <h2>쉽게 말하면 🙂</h2>
    <p class="sub">개발을 몰라도 괜찮아요. <b>AI에게 코딩을 시키면 똑똑하지만, 가끔 하던 걸 깜빡하거나 "다 했어요"라고만 하고 실제로는 안 끝낸 경우</b>가 있어요. leerness는 그 AI 옆에서 일을 <b>꼼꼼히 챙겨주는 비서</b>예요 — 직접 코딩하진 않고, AI가 실수 없이 일하도록 돕습니다.</p>
    <div class="plain-grid">
      <div class="pcard"><div class="pico">🧠</div><div class="pt">하던 일을 기억해요</div><div class="ps">대화가 끊기거나 다음 날 다시 시켜도, 어디까지 했는지 잊지 않고 이어가요.</div></div>
      <div class="pcard"><div class="pico">✅</div><div class="pt">"다 했어요"를 확인해요</div><div class="ps">정말 끝났는지 증거(테스트·결과)로 점검해서, 안 끝난 걸 끝났다고 말하지 못하게 해요.</div></div>
      <div class="pcard"><div class="pico">🛡️</div><div class="pt">사고를 미리 막아요</div><div class="ps">비밀번호 유출, 한글 깨짐 같은 흔한 실수를 일을 마치기 전에 자동으로 잡아줘요.</div></div>
      <div class="pcard"><div class="pico">🤝</div><div class="pt">다음 사람에게 넘겨줘요</div><div class="ps">다른 AI 도구나 동료가 이어받을 때, 무엇을 왜 했는지 정리해 깔끔하게 인계해요.</div></div>
    </div>
    <p class="sub" style="margin-top:18px">한 줄 요약: <b>AI가 만든 결과를 믿을 수 있게, 기억·확인·안전을 자동으로 챙겨주는 도구.</b></p>
  </section>

  <section id="about">
    <h2>leerness 란? <span style="font-size:.6em;color:#9aa0ad">(개발자용)</span></h2>
    <p class="sub">AI 코딩 에이전트(Claude Code, Cursor, Codex 등)는 코드를 잘 쓰지만 <b>기억하지 못하고, 증거 없이 "완료"를 선언</b>합니다. leerness 는 그 위에 얹는 <b>운영 레이어</b> — 프로젝트 상태를 <code>.harness/</code> 파일로 영속화하고 CLI · MCP 도구로 노출합니다. <b>leerness 자체는 LLM 을 호출하거나 코드를 실행하지 않습니다.</b></p>
    <div class="rel" style="cursor:default">
      <div class="title">🤝 핸드오프 — 세션 시작 시 컨텍스트 자동 로드, 종료 시 인수인계 생성</div>
      <div class="summ">progress-tracker · decisions · lessons · rules 를 읽어 다음 에이전트가 이어받음</div>
    </div>
    <div class="rel" style="cursor:default">
      <div class="title">🔍 자기검증 — 거짓 완료/게으름 감지 + 증거 기반 게이트</div>
      <div class="summ">done 인데 evidence 없음 · 테스트 미실행 · 추적 안 된 TODO 자동 점검</div>
    </div>
    <div class="rel" style="cursor:default">
      <div class="title">🔐 보안·인코딩 — 시크릿 스캔 + 한글 UTF-8/BOM/CRLF 검사</div>
      <div class="summ">하드코딩 시크릿·gitignore 정합·셸 스크립트 인코딩 위험 자동 탐지</div>
    </div>
  </section>

  <section id="latest">
    <h2>최근 릴리스</h2>
    <p class="sub">CHANGELOG 자동 동기화 · 총 {total}개 중 중요 업데이트 {importantCount}건</p>
    {recent.map(r => (
      <a class="rel" href={`/changelog/${r.version}`}>
        <div class="top">
          <span class="ver">v{r.version}</span>
          <span class={`badge ${badgeClass(r.category)}`}>{r.categoryKo}{r.important ? ' ★' : ''}</span>
          <span class="date">{r.date}</span>
        </div>
        <div class="title">{r.title}</div>
        {r.summary && <div class="summ">{r.summary}</div>}
      </a>
    ))}
    <p style="margin-top:14px"><a href="/changelog">전체 패치노트 →</a></p>
  </section>

  {stable.length > 0 && (
    <section id="stable">
      <h2>안정화 하이라이트</h2>
      <p class="sub">데이터 무결성 · 보안 · 호환성 — 핵심 안정화 업데이트</p>
      {stable.map(r => (
        <a class="rel" href={`/changelog/${r.version}`}>
          <div class="top">
            <span class="ver">v{r.version}</span>
            <span class={`badge ${badgeClass(r.category)}`}>{r.categoryKo}</span>
            <span class="date">{r.date}</span>
          </div>
          <div class="title">{r.title}</div>
        </a>
      ))}
    </section>
  )}
</Base>
