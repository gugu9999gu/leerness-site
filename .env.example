# leerness-site 환경변수 (키 이름만 — 실제 값은 .env 에, 절대 커밋 금지)
# 루트 ../.env 를 우선 로드하므로 거기에 둬도 됨.

# --- Cloudflare (Pages 배포) ---
CLOUDFLARE_API_KEY=        # scoped API Token (권한: Cloudflare Pages — Edit)
CLOUDFLARE_ACCOUNT_ID=     # 대시보드 우측 사이드바 Account ID (필수, 자동탐색 불가)
# CLOUDFLARE_ZONE_ID=      # leerness.com 커스텀 도메인 연결 시 (선택)

# --- YouTube Data API v3 (숏츠 업로드) ---
YOUTUBE_CLIENT_ID=         # GCP OAuth2 클라이언트 ID
YOUTUBE_CLIENT_SECRET=     # GCP OAuth2 클라이언트 시크릿
YOUTUBE_REFRESH_TOKEN=     # `npm run auth:youtube` 로 1회 발급 (헤드리스 업로드 필수)
PROJECT_ID=               # GCP 프로젝트 ID

# 참고: leerness npm 토큰 등은 ../leerness-pkg/.env 분리 관리.
